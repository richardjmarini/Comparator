.param alpha=0.02  beta=0.10  ksig=0.5
Cth_node Tj 0 {Cth} IC=0
Rth_node Tj TAMB {Rth}
Vsense Aint A DC 0
Bheat 0 Tj I = V(Aint,K)*I(Vsense)
Bres Aint K V = V(Aint,K) - I(Vsense)*( {Rmin}*exp({alpha}*(V(Tj)+V(TAMB)+{Tamb_ref}-{Tamb_ref})) + ({R1max}*exp({beta}*(V(Tj)+V(TAMB)+{Tamb_ref}-{Tcurie})) - {Rmin}*exp({alpha}*(V(Tj)+V(TAMB)+{Tamb_ref}-{Tamb_ref}))) / (1+exp(-{ksig}*(V(Tj)+V(TAMB)+{Tamb_ref}-{Tcurie}))) )
.ends 72R030X

