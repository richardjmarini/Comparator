	(text ".options method=gear gmin=1e-9 cshunt=1e-12 \n.options reltol=1e-2 abstol=1e-9 vntol=1e-6 \n.options itl1=300 itl4=300 \n.options maxstep=100p temp=60\n.tran 100u 1000ms\n.control\nrun\nplot V(\"/root/Comparator-1/NonInvertingInput\") \n     + V(\"/root/Comparator-1/InvertingInput\") V(\"/root/Comparator-2/NonInvertingInput\") \n     + V(\"/root/Comparator-1/Output\") title \"Comparator1 Output\" \nplot V(\"/root/Comparator-1/NonInvertingInput\")\n     + V(\"/root/Comparator-1/InvertingInput\") V(\"/root/Comparator-2/NonInvertingInput\") \n     + V(\"/Comparator-1-InvertedOutput\") title \"Comparator1 Inverted-Output\"\nplot V(\"/root/Comparator-2/InvertingInput\") \n     + V(\"/root/Comparator-1/InvertingInput\") V(\"/root/Comparator-2/NonInvertingInput\")   \n     + V(\"/root/Comparator-2/Output\") title \"Comparator2 Output\" \nplot V(\"/root/Comparator-2/InvertingInput\")\n     + V(\"/root/Comparator-1/InvertingInput\") V(\"/root/Comparator-2/NonInvertingInput\") \n     + V(\"/Comparator-2-InvertedOutput\") title \"Comparator2 Inverted-Output\"\n.endc"
